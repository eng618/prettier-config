{
  "name": "@eng618/prettier-config",
  "version": "2.9.0",
  "description": "My personal Prettier config",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eng618/prettier-config.git"
  },
  "license": "MIT",
  "author": "Eric N. Garcia <eng618@garciaericn.com>",
  "type": "module",
  "exports": {
    ".": "./index.js"
  },
  "scripts": {
    "format": "bunx prettier --write .",
    "lint": "bunx prettier --check .",
    "release": "echo 'Releases are handled by release-please'"
  },
  "prettier": "./index.js",
  "resolutions": {
    "@conventional-changelog/git-client": "^2.0.0",
    "semver": "^7.5.4"
  },
  "dependencies": {
    "@homer0/prettier-plugin-jsdoc": "^11.0.2",
    "prettier-plugin-curly": "^0.4.1",
    "prettier-plugin-multiline-arrays": "^4.1.4",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-packagejson": "^3.0.0",
    "prettier-plugin-prisma": "^5.0.0",
    "prettier-plugin-sh": "^0.18.0",
    "prettier-plugin-sql": "^0.19.2",
    "prettier-plugin-tailwindcss": "^0.7.2"
  },
  "devDependencies": {
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "prettier": ">=3.0.0",
    "typescript": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "packageManager": "bun@1.3.9",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "hooks": {
    "after:release": "echo Successfully released ${name} v${version} to ${repo.repository}."
  }
}
